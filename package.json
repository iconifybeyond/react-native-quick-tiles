{
  "name": "@iconifybeyond/react-native-quick-tiles",
  "version": "0.1.0",
  "description": "Add and control Android Quick Settings tiles from React Native — built on the New Architecture.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/.gradle",
    "!android/app",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "example": "yarn workspace react-native-quick-tiles-example",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "build": "bob build",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "android",
    "quick-settings",
    "quick-tiles",
    "tile-service",
    "notification-shade",
    "turbo-module",
    "new-architecture"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iconifybeyond/react-native-quick-tiles.git"
  },
  "author": "iconifybeyond",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/iconifybeyond/react-native-quick-tiles/issues"
  },
  "homepage": "https://github.com/iconifybeyond/react-native-quick-tiles#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.73.2",
    "@types/jest": "^29.5.5",
    "@types/react": "^18.2.44",
    "del-cli": "^5.1.0",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "prettier": "^2.8.8",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNQuickTilesSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.iconifybeyond.quicktiles"
    }
  }
}
